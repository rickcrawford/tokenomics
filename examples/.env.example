# ── Tokenomics Core ─────────────────────────────────────────────────────
# Required for hashing tokens. Pick a strong random secret.
TOKENOMICS_HASH_KEY=change-me-to-a-random-string

# Optional. Enables AES-256-GCM encryption of policies at rest in BoltDB.
# If unset, policies are stored as plaintext JSON.
TOKENOMICS_ENCRYPTION_KEY=another-strong-random-secret

# ── Provider API Keys ───────────────────────────────────────────────────
# Set the keys for the providers you use. Tokenomics reads them at runtime
# based on the base_key_env / api_key_env in your policy or providers.yaml.

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Azure OpenAI
AZURE_OPENAI_API_KEY=...

# Google Gemini (AI Studio)
GOOGLE_API_KEY=AIza...

# Google Vertex AI (OAuth token from: gcloud auth print-access-token)
VERTEX_AI_TOKEN=ya29...

# Mistral
MISTRAL_API_KEY=...

# Cohere
COHERE_API_KEY=...

# Groq
GROQ_API_KEY=gsk_...

# Together AI
TOGETHER_API_KEY=...

# Fireworks AI
FIREWORKS_API_KEY=...

# Perplexity
PERPLEXITY_API_KEY=pplx-...

# DeepSeek
DEEPSEEK_API_KEY=sk-...

# xAI (Grok)
XAI_API_KEY=xai-...

# OpenRouter
OPENROUTER_API_KEY=sk-or-...

# vLLM (self-hosted, optional)
VLLM_API_KEY=

# LiteLLM (proxy, optional)
LITELLM_API_KEY=
