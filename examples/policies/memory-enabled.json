{
  "base_key_env": "OPENAI_API_KEY",
  "max_tokens": 200000,
  "model_regex": "^gpt-4o",
  "prompts": [
    { "role": "system", "content": "You are a helpful assistant." }
  ],
  "rules": [
    {"type": "pii", "detect": ["ssn", "credit_card"], "action": "mask", "scope": "both"}
  ],
  "rate_limit": {
    "rules": [
      { "requests": 30, "window": "1m" }
    ]
  },
  "memory": {
    "enabled": true,
    "file_path": "./memory/sessions.md"
  },
  "metadata": {
    "team": "engineering",
    "env": "development"
  }
}
