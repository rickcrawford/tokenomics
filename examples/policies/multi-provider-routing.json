{
  "max_tokens": 500000,
  "timeout": 30,
  "prompts": [
    { "role": "system", "content": "You are a helpful assistant." }
  ],
  "rules": [
    {
      "name": "pii-mask",
      "type": "pii",
      "detect": ["ssn", "credit_card"],
      "action": "mask",
      "scope": "both"
    }
  ],
  "rate_limit": {
    "rules": [
      { "requests": 60, "window": "1m" },
      { "tokens": 200000, "window": "1h" }
    ],
    "max_parallel": 5
  },
  "retry": {
    "max_retries": 2,
    "fallbacks": ["gpt-4o-mini"],
    "retry_on": [429, 500, 502, 503]
  },
  "metadata": {
    "team": "engineering",
    "project": "chatbot",
    "env": "production"
  },
  "memory": {
    "enabled": true,
    "file_path": "/var/log/tokenomics/sessions.md"
  },
  "providers": {
    "openai": [
      {
        "base_key_env": "OPENAI_API_KEY",
        "model": "gpt-4o",
        "timeout": 120,
        "max_tokens": 100000
      },
      {
        "base_key_env": "OPENAI_API_KEY",
        "model_regex": "^gpt-4o-mini",
        "max_tokens": 500000
      }
    ],
    "anthropic": [
      {
        "base_key_env": "ANTHROPIC_API_KEY",
        "model_regex": "^claude",
        "prompts": [{ "role": "system", "content": "Be concise." }]
      }
    ],
    "groq": [
      {
        "base_key_env": "GROQ_API_KEY",
        "model_regex": "^llama"
      }
    ]
  }
}
