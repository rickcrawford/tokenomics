# ── Tokenomics Core ──────────────────────────────────────────────────
# Must match between central config server and all proxy instances.
TOKENOMICS_HASH_KEY=change-me-to-a-strong-random-string
TOKENOMICS_ENCRYPTION_KEY=change-me-another-strong-secret

# ── Remote Sync ──────────────────────────────────────────────────────
# API key for authenticating proxy-to-central-server communication.
TOKENOMICS_REMOTE_KEY=change-me-remote-api-key

# ── Webhook Secrets ──────────────────────────────────────────────────
TOKENOMICS_WEBHOOK_SECRET=change-me-webhook-secret
TOKENOMICS_SIGNING_KEY=change-me-signing-key

# ── Provider API Keys ────────────────────────────────────────────────
# Set the keys for providers your team uses. Only needed on proxy machines.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...
MISTRAL_API_KEY=...
