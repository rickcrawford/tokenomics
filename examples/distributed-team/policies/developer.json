{
  "max_tokens": 200000,
  "timeout": 60,
  "prompts": [
    { "role": "system", "content": "You are a helpful engineering assistant." }
  ],
  "rules": [
    {
      "name": "pii-mask",
      "type": "pii",
      "detect": ["ssn", "credit_card", "aws_key", "api_key"],
      "action": "mask",
      "scope": "both"
    }
  ],
  "rate_limit": {
    "rules": [
      { "requests": 60, "window": "1m" },
      { "tokens": 200000, "window": "1h" }
    ],
    "max_parallel": 5
  },
  "retry": {
    "max_retries": 2,
    "fallbacks": ["gpt-4o-mini"],
    "retry_on": [429, 500, 502, 503]
  },
  "metadata": {
    "role": "developer",
    "team": "engineering"
  },
  "memory": {
    "enabled": true,
    "file_path": "/var/log/tokenomics/sessions",
    "file_name": "{token_hash}.md"
  },
  "providers": {
    "openai": [
      {
        "base_key_env": "OPENAI_API_KEY",
        "model": "gpt-4o",
        "max_tokens": 100000
      },
      {
        "base_key_env": "OPENAI_API_KEY",
        "model_regex": "^gpt-4o-mini",
        "max_tokens": 200000
      }
    ],
    "anthropic": [
      {
        "base_key_env": "ANTHROPIC_API_KEY",
        "model_regex": "^claude"
      }
    ]
  }
}
