{
  "max_tokens": 1000000,
  "timeout": 120,
  "prompts": [
    { "role": "system", "content": "You are a helpful engineering assistant." }
  ],
  "rules": [
    {
      "name": "pii-warn",
      "type": "pii",
      "detect": ["ssn", "credit_card", "aws_key", "private_key"],
      "action": "warn",
      "scope": "both"
    }
  ],
  "rate_limit": {
    "rules": [
      { "requests": 120, "window": "1m" },
      { "tokens": 500000, "window": "1h" }
    ],
    "max_parallel": 10
  },
  "retry": {
    "max_retries": 3,
    "fallbacks": ["gpt-4o-mini"],
    "retry_on": [429, 500, 502, 503]
  },
  "metadata": {
    "role": "lead-engineer",
    "team": "engineering"
  },
  "memory": {
    "enabled": true,
    "file_path": "/var/log/tokenomics/sessions",
    "file_name": "{token_hash}.md"
  },
  "providers": {
    "openai": [
      {
        "base_key_env": "OPENAI_API_KEY",
        "model": "gpt-4o",
        "timeout": 120,
        "max_tokens": 500000
      },
      {
        "base_key_env": "OPENAI_API_KEY",
        "model_regex": "^(gpt-4o-mini|o3-mini|o4-mini)",
        "max_tokens": 1000000
      }
    ],
    "anthropic": [
      {
        "base_key_env": "ANTHROPIC_API_KEY",
        "model_regex": "^claude"
      }
    ],
    "groq": [
      {
        "base_key_env": "GROQ_API_KEY",
        "model_regex": "^llama"
      }
    ],
    "mistral": [
      {
        "base_key_env": "MISTRAL_API_KEY",
        "model_regex": "^mistral"
      }
    ]
  }
}
