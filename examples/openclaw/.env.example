# OpenClaw + Tokenomics Integration Environment Variables
# Copy this to .env and fill in your actual values

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Tokenomics Security Keys (generate with: openssl rand -hex 16 for each)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 32-character hex key for HMAC token hashing (openssl rand -hex 16)
TOKENOMICS_HASH_KEY=0123456789abcdef0123456789abcdef

# 32-character hex key for AES-256-GCM encryption (openssl rand -hex 16)
TOKENOMICS_ENCRYPTION_KEY=fedcba9876543210fedcba9876543210

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# LLM Provider API Keys
# Use custom env var names (not the defaults) for PAT isolation
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# OpenAI API key (from https://platform.openai.com/api-keys)
# Using custom env var name: OPENAI_PAT (not OPENAI_API_KEY)
OPENAI_PAT=sk-proj-your-openai-key-here

# Anthropic API key (from https://console.anthropic.com/)
# Using custom env var name: ANTHROPIC_PAT (not ANTHROPIC_API_KEY)
ANTHROPIC_PAT=sk-ant-your-anthropic-key-here

# Azure OpenAI API key (if using Azure)
# Using custom env var name: AZURE_OPENAI_PAT
AZURE_OPENAI_PAT=your-azure-openai-key

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Tokenomics Server Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Working directory for tokenomics data (tokens, ledger, certs)
# Defaults to .tokenomics in current directory if not set
# Use ~/.tokenomics for persistent setup across projects
TOKENOMICS_DIR=${HOME}/.tokenomics

# Tokenomics server port
TOKENOMICS_HTTP_PORT=8080
TOKENOMICS_HTTPS_PORT=8443

# Session backend: memory (for single instance) or redis (for distributed)
TOKENOMICS_SESSION_BACKEND=memory

# Redis config (only if SESSION_BACKEND=redis)
TOKENOMICS_REDIS_ADDR=localhost:6379
TOKENOMICS_REDIS_PASSWORD=
TOKENOMICS_REDIS_DB=0

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Logging Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

TOKENOMICS_LOGGING_LEVEL=info
TOKENOMICS_LOGGING_FORMAT=json
TOKENOMICS_LOGGING_REQUEST_BODY=false
TOKENOMICS_LOGGING_RESPONSE_BODY=false

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Ledger Configuration (for session recording and cost tracking)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

TOKENOMICS_LEDGER_ENABLED=true
TOKENOMICS_LEDGER_MEMORY=true

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Webhook Configuration (for events to external systems)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Webhook endpoint URL (where to send events)
WEBHOOK_URL=http://localhost:9090/webhook

# Shared secret for webhook authentication
WEBHOOK_SECRET=my-webhook-secret

# HMAC-SHA256 signing key for webhook signatures
WEBHOOK_SIGNING_KEY=my-signing-key

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OpenClaw Integration Specifics
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Tokenomics endpoint that OpenClaw agents will connect to
# For local testing: http://localhost:8080
# For remote: https://tokenomics.example.com
TOKENOMICS_ENDPOINT=http://localhost:8080

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Docker/Compose Environment (ignore if not using docker-compose)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

COMPOSE_PROJECT_NAME=openclaw-tokenomics
