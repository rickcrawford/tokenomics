{
  "base_key_env": "OPENAI_PAT",
  "max_tokens": 500000,

  "providers": {
    "openai": [
      {
        "base_key_env": "OPENAI_PAT",
        "model_regex": "^gpt-4.*",
        "max_tokens": 2000
      },
      {
        "base_key_env": "OPENAI_PAT",
        "model_regex": "^gpt-3\\.5.*",
        "max_tokens": 4000
      }
    ],
    "anthropic": [
      {
        "base_key_env": "ANTHROPIC_PAT",
        "model_regex": "^claude.*",
        "max_tokens": 2000
      }
    ]
  },

  "memory": {
    "enabled": true,
    "file_path": ".tokenomics/memory",
    "file_name": "{date}/{token_hash}.md"
  },

  "rate_limit": {
    "rules": [
      {
        "requests": 50,
        "window": "1m",
        "strategy": "sliding"
      },
      {
        "tokens": 500000,
        "window": "24h",
        "strategy": "fixed"
      },
      {
        "tokens": 50000,
        "window": "1h",
        "strategy": "sliding"
      }
    ],
    "max_parallel": 3
  },

  "retry": {
    "max_retries": 2,
    "retry_on": [429, 500, 502, 503]
  },

  "rules": [
    {
      "name": "Warn on jailbreak attempts",
      "type": "jailbreak",
      "action": "warn",
      "scope": "input"
    },
    {
      "name": "Mask PII in input",
      "type": "pii",
      "detect": ["email", "phone", "ssn"],
      "action": "mask",
      "scope": "input"
    },
    {
      "name": "Mask secrets in output",
      "type": "pii",
      "detect": ["api_key", "private_key", "jwt"],
      "action": "mask",
      "scope": "output"
    },
    {
      "name": "Block suspicious code patterns",
      "type": "regex",
      "pattern": "(?i)(eval|exec|__import__|subprocess)\\s*\\(",
      "action": "log",
      "scope": "input"
    }
  ],

  "metadata": {
    "agent_id": "discord-bot",
    "agent_type": "discord",
    "team": "default",
    "environment": "production",
    "cost_center": "engineering"
  }
}
